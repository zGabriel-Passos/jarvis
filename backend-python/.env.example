# 1. Acesse https://console.groq.com/keys
# 2. Crie uma conta gratuita ou login
# 3. Clique em "Create API Key"
# 4. Copie a chave e cole abaixo
GROQ_API_KEY=sua_chave_aqui

# 1. Acesse https://elevenlabs.io e crie uma conta
# 2. Vá em Profile → API Key
# 3. Gere uma nova chave e ATIVE a permissão "Text to Speech"
# 4. Copie a chave e cole abaixo
ELEVENLABS_API_KEY=sua_chave_aqui

# Depois, renomeie este arquivo de .env.example para .env
# cp .env.example .env
